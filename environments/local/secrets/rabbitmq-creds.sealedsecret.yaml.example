# SealedSecret EXAMPLE — rabbitmq-creds.
#
# Placeholder. See platform/secrets/README.md for the kubeseal commands.
#
# Resulting Secret:
#   namespace: saga
#   name:      rabbitmq-creds
#   keys:
#     RabbitMq__Username
#     RabbitMq__Password
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: rabbitmq-creds
  namespace: saga
spec:
  encryptedData:
    RabbitMq__Username: REPLACE_ME_AFTER_SEALING
    RabbitMq__Password: REPLACE_ME_AFTER_SEALING
  template:
    metadata:
      name: rabbitmq-creds
      namespace: saga
    type: Opaque
