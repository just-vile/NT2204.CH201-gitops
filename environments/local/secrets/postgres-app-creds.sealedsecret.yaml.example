# SealedSecret EXAMPLE — postgres-app-creds.
#
# This file is a placeholder. The encryptedData below is NOT a real seal —
# it will never decrypt against any controller. To produce the working
# SealedSecret:
#   1. Install kubeseal (see platform/secrets/README.md).
#   2. Fetch the controller's public key (kubeseal --fetch-cert).
#   3. Build a plain Secret with the keys below + your chosen password,
#      pipe through kubeseal --format yaml, and write the result to
#      postgres-app-creds.sealedsecret.yaml (no `.example`).
#   4. Commit the sealed file. The .example file stays as documentation.
#
# Resulting Secret:
#   namespace: saga
#   name:      postgres-app-creds
#   keys:
#     username
#     password
#     ConnectionStrings__Postgres__order
#     ConnectionStrings__Postgres__payment
#     ConnectionStrings__Postgres__inventory
#     ConnectionStrings__Postgres__shipping
#
# The four `ConnectionStrings__Postgres__<svc>` keys are consumed by the
# saga services via envFromSecrets (see environments/local/values-<svc>.yaml).
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: postgres-app-creds
  namespace: saga
spec:
  encryptedData:
    username: REPLACE_ME_AFTER_SEALING
    password: REPLACE_ME_AFTER_SEALING
    ConnectionStrings__Postgres__order: REPLACE_ME_AFTER_SEALING
    ConnectionStrings__Postgres__payment: REPLACE_ME_AFTER_SEALING
    ConnectionStrings__Postgres__inventory: REPLACE_ME_AFTER_SEALING
    ConnectionStrings__Postgres__shipping: REPLACE_ME_AFTER_SEALING
  template:
    metadata:
      name: postgres-app-creds
      namespace: saga
    type: kubernetes.io/basic-auth
