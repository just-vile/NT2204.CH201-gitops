# SealedSecret EXAMPLE — postgres-superuser-creds.
#
# Placeholder. See platform/secrets/README.md for the kubeseal commands.
#
# Resulting Secret:
#   namespace: saga
#   name:      postgres-superuser-creds
#   keys:
#     username      (typically "postgres")
#     password
#
# CloudNativePG references this via Cluster.spec.superuserSecret.name.
# The saga app pods do NOT use these credentials — they use postgres-app-creds.
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: postgres-superuser-creds
  namespace: saga
spec:
  encryptedData:
    username: REPLACE_ME_AFTER_SEALING
    password: REPLACE_ME_AFTER_SEALING
  template:
    metadata:
      name: postgres-superuser-creds
      namespace: saga
    type: kubernetes.io/basic-auth
